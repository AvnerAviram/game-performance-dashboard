{
  "name": "game-analytics-dashboard",
  "version": "1.0.0",
  "description": "Game Analytics Performance Dashboard",
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./src/output.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./src/output.css --watch",
    "dev": "vite",
    "build": "npm run build:css && vite build && mkdir -p dist/data dist/src/pages dist/src/config && cp data/games_dashboard.json data/theme_consolidation_map.json dist/data/ && cp -r src/pages dist/src/ && cp src/config/theme-breakdowns.json dist/src/config/ && node scripts/build/write-health-json.cjs",
    "preview": "vite preview",
    "test:visual": "playwright test tests/visual-regression/",
    "test:alignment": "playwright test tests/alignment/",
    "test": "node scripts/run-tests.cjs",
    "test:vitest": "vitest run --coverage && node scripts/print-coverage.cjs",
    "test:all": "vitest run --coverage && npm run test:e2e",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit/",
    "test:integration": "vitest run tests/integration/",
    "test:validation": "vitest run tests/data-validation/",
    "test:e2e": "node node_modules/@playwright/test/cli.js test tests/e2e/dashboard-navigation.spec.js --project=chromium",
    "test:playwright": "npx playwright test tests/playwright-consolidated.spec.js --project=chromium",
    "test:playwright:update": "npx playwright test tests/playwright-consolidated.spec.js --project=chromium --update-snapshots",
    "serve": "python3 -m http.server 8000",
    "verify": "node scripts/data/verify-and-correct-games.mjs",
    "verify:dry": "node scripts/data/verify-and-correct-games.mjs --dry-run",
    "verify:dry-skip-web": "node scripts/data/verify-and-correct-games.mjs --dry-run --skip-web",
    "serve:e2e": "npm run build && vite preview --port 8000",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.40.0",
    "@vitejs/plugin-legacy": "^7.2.1",
    "@vitest/coverage-v8": "^2.1.9",
    "axios": "^1.13.5",
    "cheerio": "^1.0.0-rc.12",
    "eslint": "^10.0.0",
    "globals": "^17.3.0",
    "jsdom": "^25.0.0",
    "p-limit": "^7.3.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@sentry/browser": "^10.38.0",
    "bcryptjs": "^3.0.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0"
  },
  "type": "module"
}
