{
    "ci": {
        "collect": {
            "staticDistDir": "./dist",
            "numberOfRuns": 1,
            "settings": {
                "preset": "desktop"
            }
        },
        "assert": {
            "assertions": {
                "categories:performance": ["warn", { "minScore": 0.5 }],
                "categories:accessibility": ["warn", { "minScore": 0.7 }],
                "categories:best-practices": ["warn", { "minScore": 0.8 }]
            }
        }
    }
}
