# ---- Required in production ----
SESSION_SECRET=generate-a-strong-random-string-here

# ---- Optional ----
PORT=3000
NODE_ENV=production

# Claude API key for AI Name Generator and AI Assistant (leave empty to disable)
CLAUDE_API_KEY=

# Secret code users must enter to access AI name generation (prevents cost abuse)
AI_NAME_CODE=

# Max AI name generation calls per day across all users (cost control)
AI_DAILY_CAP=50

# Debug logging (also enabled by localhost or ?debug=1 in URL)
DEBUG=false

# Sentry DSN for error tracking
# VITE_SENTRY_DSN=
