#!/bin/sh
# Pre-commit gate: tests + format must pass before committing.
# Installed by: npm run prepare (sets git core.hooksPath)

cd "$(git rev-parse --show-toplevel)/game_analytics_export" || exit 1

echo "🔒 Pre-commit gate: running tests..."

# Format check (fast, catches obvious issues)
npm run format:check 2>&1
if [ $? -ne 0 ]; then
    echo "❌ Formatting check failed. Run: npm run format"
    exit 1
fi

# Full test suite (no exclusions)
SKIP_LIVE_API=true npm test 2>&1
if [ $? -ne 0 ]; then
    echo "❌ Tests failed. Fix before committing."
    exit 1
fi

echo "✅ All checks passed."
